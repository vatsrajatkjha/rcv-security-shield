{
    "name": "vendor-shield/laravel-shield",
    "description": "Enterprise Runtime Security Platform for Laravel Applications",
    "keywords": ["laravel", "security", "rasp", "runtime-security", "waf", "enterprise"],
    "authors": [
        {
            "name": "Rajat Kumar Jha",
            "organization": "RCV Technologies"
        }
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/log": "^11.0|^12.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^9.0|^10.0",
        "phpstan/phpstan": "^1.12",
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "VendorShield\\Shield\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VendorShield\\Shield\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VendorShield\\Shield\\ShieldServiceProvider"
            ],
            "aliases": {
                "Shield": "VendorShield\\Shield\\Facades\\Shield"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "analyse": "phpstan analyse src tests --memory-limit=512M --debug",
        "lint": "pint --test"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
